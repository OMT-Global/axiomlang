{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://omt-global.github.io/axiom/schemas/axiom.compiler.stdlib_catalog.v1.schema.json","title":"AxiOM compiler standard-library catalog","type":"object","additionalProperties":false,"required":["schema_version","contract","catalog_version","source","modules","release_digest","rollback_boundary"],"properties":{"schema_version":{"const":"axiom.compiler.stdlib_catalog.v1"},"contract":{"const":"compiler.stdlib"},"catalog_version":{"const":"1.0.0"},"source":{"const":"stage1/compiler-contracts/snapshots/capability-ledger.json"},"modules":{"type":"array","minItems":1},"release_digest":{"type":"string","pattern":"^[0-9a-f]{64}$"},"rollback_boundary":{"const":"stage1/crates/axiomc/src/stdlib.rs remains the bootstrap loader until the qualified compiler path consumes this catalog."}}}
