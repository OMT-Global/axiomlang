{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omt-global.github.io/axiom/schemas/axiom.semantic_mir.v1.schema.json",
  "title": "Axiom Semantic MIR v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "contract", "issue", "package_id", "features", "functions", "migration"],
  "properties": {
    "schema_version": {"const": "axiom.semantic_mir.v1"},
    "contract": {"const": "compiler.semantic_mir"},
    "issue": {"const": 1437},
    "package_id": {"type": "string", "pattern": "^axiom://"},
    "features": {"type": "array", "minItems": 12, "items": {"enum": ["scalar_call", "branch", "loop", "match", "try", "mutation", "early_return", "panic", "defer", "capability_call", "aggregate", "async_boundary"]}},
    "functions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/function"}},
    "migration": {"$ref": "#/$defs/migration"}
  },
  "$defs": {
    "node_id": {"type": "string", "pattern": "^axiom://[A-Za-z0-9._~:/#@!$&'()*+,;=%-]+$"},
    "span": {"type": "object", "additionalProperties": false, "required": ["path", "line", "column"], "properties": {"path": {"type": "string", "minLength": 1}, "line": {"type": "integer", "minimum": 1}, "column": {"type": "integer", "minimum": 1}}},
    "function": {"type": "object", "additionalProperties": false, "required": ["id", "span", "blocks"], "properties": {"id": {"$ref": "#/$defs/node_id"}, "span": {"$ref": "#/$defs/span"}, "blocks": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/block"}}}},
    "block": {"type": "object", "additionalProperties": false, "required": ["id", "parameters", "instructions", "terminator", "span", "semantic_nodes"], "properties": {"id": {"$ref": "#/$defs/node_id"}, "parameters": {"type": "array", "items": {"$ref": "#/$defs/node_id"}}, "instructions": {"type": "array", "items": {"$ref": "#/$defs/instruction"}}, "terminator": {"enum": ["goto", "branch", "match", "return", "panic", "unwind", "unreachable"]}, "span": {"$ref": "#/$defs/span"}, "semantic_nodes": {"type": "array", "items": {"$ref": "#/$defs/node_id"}}}},
    "instruction": {"type": "object", "additionalProperties": false, "required": ["id", "op", "span", "semantic_nodes"], "properties": {"id": {"$ref": "#/$defs/node_id"}, "op": {"enum": ["const", "copy", "move", "borrow", "load", "store", "aggregate", "call", "capability_call", "binary", "cast", "await", "drop", "defer_scope"]}, "span": {"$ref": "#/$defs/span"}, "semantic_nodes": {"type": "array", "items": {"$ref": "#/$defs/node_id"}}}},
    "migration": {"type": "object", "additionalProperties": false, "required": ["legacy_projection", "backend_consumption", "forbidden_terms"], "properties": {"legacy_projection": {"type": "string", "minLength": 1}, "backend_consumption": {"type": "string", "minLength": 1}, "forbidden_terms": {"type": "array", "minItems": 4, "items": {"type": "string", "minLength": 1}}}}
  }
}
