{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omt-global.github.io/axiom/schemas/axiom.semantic_mir.v1.schema.json",
  "title": "Axiom Semantic MIR v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "contract", "issue", "package_id", "features", "functions", "migration"],
  "properties": {
    "schema_version": {"const": "axiom.semantic_mir.v1"},
    "contract": {"const": "compiler.semantic_mir"},
    "issue": {"const": 1437},
    "package_id": {"type": "string", "pattern": "^axiom://"},
    "features": {"$ref": "#/$defs/features"},
    "functions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/function"}},
    "migration": {"$ref": "#/$defs/migration"}
  },
  "$defs": {
    "node_id": {"type": "string", "pattern": "^axiom://[A-Za-z0-9._~:/#@!$&'()*+,;=%-]+$"},
    "feature": {"enum": ["scalar_call", "branch", "loop", "match", "try", "mutation", "early_return", "panic", "defer", "capability_call", "aggregate", "async_boundary"]},
    "features": {"$comment": "Semantic MIR v1 freezes this vocabulary. The checker derives its expected set from this enum and requires executable evidence for each feature.", "type": "array", "minItems": 12, "items": {"$ref": "#/$defs/feature"}},
    "span": {"type": "object", "additionalProperties": false, "required": ["path", "line", "column"], "properties": {"path": {"type": "string", "minLength": 1}, "line": {"type": "integer", "minimum": 1}, "column": {"type": "integer", "minimum": 1}}},
    "provenance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/node_id"}},
    "value": {"type": "object", "additionalProperties": false, "required": ["id", "type", "span", "semantic_nodes"], "properties": {"id": {"$ref": "#/$defs/node_id"}, "type": {"type": "string", "minLength": 1}, "span": {"$ref": "#/$defs/span"}, "semantic_nodes": {"$ref": "#/$defs/provenance"}}},
    "projection": {"type": "object", "additionalProperties": false, "required": ["kind"], "properties": {"kind": {"enum": ["field", "tuple", "index", "deref", "slice"]}, "field": {"type": "string", "minLength": 1}, "index": {"type": "integer", "minimum": 0}}},
    "place": {"type": "object", "additionalProperties": false, "required": ["id", "base", "projections", "span", "semantic_nodes"], "properties": {"id": {"$ref": "#/$defs/node_id"}, "base": {"$ref": "#/$defs/node_id"}, "projections": {"type": "array", "items": {"$ref": "#/$defs/projection"}}, "span": {"$ref": "#/$defs/span"}, "semantic_nodes": {"$ref": "#/$defs/provenance"}}},
    "instruction": {"type": "object", "additionalProperties": false, "required": ["id", "op", "operands", "features", "span", "semantic_nodes"], "properties": {"id": {"$ref": "#/$defs/node_id"}, "op": {"$comment": "The fixture covers every operation in this frozen vocabulary.", "enum": ["const", "copy", "move", "borrow", "load", "store", "aggregate", "call", "capability_call", "binary", "cast", "await", "drop", "defer_scope"]}, "operands": {"type": "array", "items": {"$ref": "#/$defs/node_id"}}, "result": {"$ref": "#/$defs/value"}, "place": {"$ref": "#/$defs/node_id"}, "callee": {"type": "string", "minLength": 1}, "effects": {"type": "array", "items": {"type": "string", "minLength": 1}}, "capability": {"type": "string", "minLength": 1}, "cleanup_scope": {"$ref": "#/$defs/node_id"}, "features": {"type": "array", "items": {"$ref": "#/$defs/feature"}}, "span": {"$ref": "#/$defs/span"}, "semantic_nodes": {"$ref": "#/$defs/provenance"}}},
    "successor": {"type": "object", "additionalProperties": false, "required": ["target", "arguments"], "properties": {"target": {"$ref": "#/$defs/node_id"}, "arguments": {"type": "array", "items": {"$ref": "#/$defs/node_id"}}}},
    "terminator": {"type": "object", "additionalProperties": false, "required": ["op", "operands", "successors", "features", "span", "semantic_nodes"], "properties": {"op": {"$comment": "The fixture covers every v1 terminator and its explicit successor edges.", "enum": ["goto", "branch", "match", "return", "panic", "unwind", "unreachable"]}, "operands": {"type": "array", "items": {"$ref": "#/$defs/node_id"}}, "successors": {"type": "array", "items": {"$ref": "#/$defs/successor"}}, "cleanup_scopes": {"type": "array", "items": {"$ref": "#/$defs/node_id"}}, "features": {"type": "array", "items": {"$ref": "#/$defs/feature"}}, "span": {"$ref": "#/$defs/span"}, "semantic_nodes": {"$ref": "#/$defs/provenance"}}},
    "cleanup_scope": {"type": "object", "additionalProperties": false, "required": ["id", "mode", "actions", "span", "semantic_nodes"], "properties": {"id": {"$ref": "#/$defs/node_id"}, "mode": {"enum": ["always", "on_success", "on_failure"]}, "actions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/node_id"}}, "span": {"$ref": "#/$defs/span"}, "semantic_nodes": {"$ref": "#/$defs/provenance"}}},
    "block": {"type": "object", "additionalProperties": false, "required": ["id", "parameters", "instructions", "terminator", "span", "semantic_nodes"], "properties": {"id": {"$ref": "#/$defs/node_id"}, "parameters": {"type": "array", "items": {"$ref": "#/$defs/value"}}, "instructions": {"type": "array", "items": {"$ref": "#/$defs/instruction"}}, "terminator": {"$ref": "#/$defs/terminator"}, "span": {"$ref": "#/$defs/span"}, "semantic_nodes": {"$ref": "#/$defs/provenance"}}},
    "function": {"type": "object", "additionalProperties": false, "required": ["id", "span", "semantic_nodes", "places", "cleanup_scopes", "blocks"], "properties": {"id": {"$ref": "#/$defs/node_id"}, "span": {"$ref": "#/$defs/span"}, "semantic_nodes": {"$ref": "#/$defs/provenance"}, "places": {"type": "array", "items": {"$ref": "#/$defs/place"}}, "cleanup_scopes": {"type": "array", "items": {"$ref": "#/$defs/cleanup_scope"}}, "blocks": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/block"}}}},
    "migration": {"type": "object", "additionalProperties": false, "required": ["legacy_projection", "backend_consumption", "forbidden_terms"], "properties": {"legacy_projection": {"type": "string", "minLength": 1}, "backend_consumption": {"type": "string", "minLength": 1}, "forbidden_terms": {"type": "array", "minItems": 4, "items": {"type": "string", "minLength": 1}}}}
  }
}
