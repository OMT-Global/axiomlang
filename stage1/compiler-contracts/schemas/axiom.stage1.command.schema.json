{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omt-global.github.io/axiom/schemas/axiom.stage1.command.schema.json",
  "title": "Axiom stage1 compiler command JSON envelope",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/check"
    },
    {
      "$ref": "#/$defs/build"
    },
    {
      "$ref": "#/$defs/run"
    },
    {
      "$ref": "#/$defs/test"
    },
    {
      "$ref": "#/$defs/caps"
    },
    {
      "$ref": "#/$defs/mutationReport"
    }
  ],
  "$defs": {
    "schemaVersion": {
      "const": "axiom.stage1.v1"
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "durationMs": {
      "type": "integer",
      "minimum": 0
    },
    "statementCount": {
      "type": "integer",
      "minimum": 0
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "enabled"
      ],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "fs",
            "fs:write",
            "net",
            "process",
            "env",
            "clock",
            "crypto",
            "ffi",
            "async"
          ]
        },
        "description": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "allowed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "configured_root": {
          "type": "string",
          "minLength": 1
        },
        "effective_root": {
          "type": "string",
          "minLength": 1
        },
        "package_root": {
          "type": "string",
          "minLength": 1
        },
        "deny_by_default": {
          "type": "boolean"
        },
        "unsafe_unrestricted": {
          "type": "boolean"
        },
        "unsafe_opt_in": {
          "type": "boolean"
        },
        "unsafe_rationale": {
          "type": "string"
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "checkPackage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest",
        "entry",
        "package_root",
        "statement_count",
        "capabilities",
        "warnings"
      ],
      "properties": {
        "manifest": {
          "$ref": "#/$defs/path"
        },
        "entry": {
          "$ref": "#/$defs/path"
        },
        "package_root": {
          "$ref": "#/$defs/path"
        },
        "statement_count": {
          "$ref": "#/$defs/statementCount"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/capability"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "macro_expansions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/macroExpansion"
          }
        }
      }
    },
    "buildPackage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest",
        "entry",
        "package_root",
        "statement_count",
        "backend",
        "binary",
        "generated_rust",
        "debug_map",
        "debug_manifest",
        "target",
        "debug",
        "cache_status",
        "compile_ms",
        "metadata",
        "cache_key"
      ],
      "properties": {
        "manifest": {
          "$ref": "#/$defs/path"
        },
        "entry": {
          "$ref": "#/$defs/path"
        },
        "package_root": {
          "$ref": "#/$defs/path"
        },
        "statement_count": {
          "$ref": "#/$defs/statementCount"
        },
        "backend": {
          "type": "string",
          "minLength": 1
        },
        "binary": {
          "$ref": "#/$defs/path"
        },
        "generated_rust": {
          "$ref": "#/$defs/path"
        },
        "debug_map": {
          "type": [
            "string",
            "null"
          ]
        },
        "debug_manifest": {
          "type": [
            "string",
            "null"
          ]
        },
        "target": {
          "type": [
            "string",
            "null"
          ]
        },
        "debug": {
          "type": "boolean"
        },
        "cache_status": {
          "enum": [
            "hit",
            "miss"
          ]
        },
        "compile_ms": {
          "$ref": "#/$defs/durationMs"
        },
        "metadata": {
          "$ref": "#/$defs/buildMetadata"
        },
        "cache_key": {
          "$ref": "#/$defs/cacheKey"
        }
      }
    },
    "testCase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "entry",
        "package_root",
        "binary",
        "generated_rust",
        "ok",
        "exit_code",
        "stdout",
        "stderr",
        "expected_stdout",
        "duration_ms",
        "error",
        "expected_stderr"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "entry": {
          "type": "string",
          "minLength": 1
        },
        "package_root": {
          "$ref": "#/$defs/path"
        },
        "binary": {
          "$ref": "#/$defs/path"
        },
        "generated_rust": {
          "$ref": "#/$defs/path"
        },
        "ok": {
          "type": "boolean"
        },
        "exit_code": {
          "type": "integer"
        },
        "stdout": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        },
        "expected_stdout": {
          "type": "string"
        },
        "duration_ms": {
          "$ref": "#/$defs/durationMs"
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "expected_stderr": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "mutationSurvivor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "mutator",
        "line",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "mutator": {
          "type": "string",
          "minLength": 1
        },
        "line": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "mutationGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file",
        "function",
        "recommended_fixture",
        "survivors"
      ],
      "properties": {
        "file": {
          "type": "string",
          "minLength": 1
        },
        "function": {
          "type": "string",
          "minLength": 1
        },
        "recommended_fixture": {
          "type": "string",
          "minLength": 1
        },
        "survivors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/mutationSurvivor"
          }
        }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "ok",
        "command",
        "project",
        "manifest",
        "entry",
        "statement_count",
        "capabilities",
        "warnings",
        "packages",
        "exports"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schemaVersion"
        },
        "project": {
          "$ref": "#/$defs/path"
        },
        "ok": {
          "const": true
        },
        "command": {
          "const": "check"
        },
        "manifest": {
          "$ref": "#/$defs/path"
        },
        "entry": {
          "$ref": "#/$defs/path"
        },
        "statement_count": {
          "$ref": "#/$defs/statementCount"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/capability"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "packages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/checkPackage"
          }
        },
        "exports": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "macro_expansions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/macroExpansion"
          }
        }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "ok",
        "command",
        "project",
        "backend",
        "locked",
        "offline",
        "manifest",
        "entry",
        "binary",
        "generated_rust",
        "debug_map",
        "debug_manifest",
        "statement_count",
        "target",
        "debug",
        "metadata",
        "cache_hits",
        "cache_misses",
        "duration_ms",
        "packages",
        "cache_key"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schemaVersion"
        },
        "project": {
          "$ref": "#/$defs/path"
        },
        "ok": {
          "const": true
        },
        "command": {
          "const": "build"
        },
        "backend": {
          "type": "string",
          "minLength": 1
        },
        "locked": {
          "type": "boolean"
        },
        "offline": {
          "type": "boolean"
        },
        "manifest": {
          "$ref": "#/$defs/path"
        },
        "entry": {
          "$ref": "#/$defs/path"
        },
        "binary": {
          "$ref": "#/$defs/path"
        },
        "generated_rust": {
          "$ref": "#/$defs/path"
        },
        "debug_map": {
          "type": [
            "string",
            "null"
          ]
        },
        "debug_manifest": {
          "type": [
            "string",
            "null"
          ]
        },
        "statement_count": {
          "$ref": "#/$defs/statementCount"
        },
        "target": {
          "type": [
            "string",
            "null"
          ]
        },
        "debug": {
          "type": "boolean"
        },
        "metadata": {
          "$ref": "#/$defs/buildMetadata"
        },
        "cache_hits": {
          "type": "integer",
          "minimum": 0
        },
        "cache_misses": {
          "type": "integer",
          "minimum": 0
        },
        "duration_ms": {
          "$ref": "#/$defs/durationMs"
        },
        "packages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/buildPackage"
          }
        },
        "cache_key": {
          "$ref": "#/$defs/cacheKey"
        }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "ok",
        "command",
        "project",
        "manifest",
        "entry",
        "binary",
        "generated_rust",
        "package",
        "args",
        "exit_code",
        "result",
        "stdout",
        "stderr",
        "duration_ms"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schemaVersion"
        },
        "project": {
          "$ref": "#/$defs/path"
        },
        "ok": {
          "type": "boolean"
        },
        "command": {
          "const": "run"
        },
        "manifest": {
          "$ref": "#/$defs/path"
        },
        "entry": {
          "$ref": "#/$defs/path"
        },
        "binary": {
          "$ref": "#/$defs/path"
        },
        "generated_rust": {
          "$ref": "#/$defs/path"
        },
        "package": {
          "type": [
            "string",
            "null"
          ]
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exit_code": {
          "type": "integer"
        },
        "result": {
          "enum": [
            "success",
            "failure"
          ]
        },
        "stdout": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        },
        "duration_ms": {
          "$ref": "#/$defs/durationMs"
        }
      }
    },
    "test": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "ok",
        "command",
        "project",
        "manifest",
        "packages",
        "filter",
        "properties_only",
        "passed",
        "failed",
        "skipped",
        "kinds",
        "properties",
        "duration_ms",
        "cases"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schemaVersion"
        },
        "project": {
          "$ref": "#/$defs/path"
        },
        "ok": {
          "type": "boolean"
        },
        "command": {
          "const": "test"
        },
        "manifest": {
          "$ref": "#/$defs/path"
        },
        "packages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/path"
          }
        },
        "filter": {
          "type": [
            "string",
            "null"
          ]
        },
        "properties_only": {
          "type": "boolean"
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        },
        "kinds": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "properties": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "passed",
            "failed",
            "total"
          ],
          "properties": {
            "passed": {
              "type": "integer",
              "minimum": 0
            },
            "failed": {
              "type": "integer",
              "minimum": 0
            },
            "total": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "duration_ms": {
          "$ref": "#/$defs/durationMs"
        },
        "cases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/testCase"
          }
        }
      }
    },
    "mutationReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "ok",
        "command",
        "survivor_count",
        "groups"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schemaVersion"
        },
        "ok": {
          "const": true
        },
        "command": {
          "const": "mutation-report"
        },
        "survivor_count": {
          "type": "integer",
          "minimum": 0
        },
        "groups": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/mutationGroup"
          }
        }
      }
    },
    "caps": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "ok",
        "command",
        "project",
        "capabilities",
        "manifest",
        "requested",
        "granted",
        "denied",
        "unsafe",
        "transitive_package_usage",
        "stdlib_modules"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schemaVersion"
        },
        "project": {
          "$ref": "#/$defs/path"
        },
        "ok": {
          "const": true
        },
        "command": {
          "const": "caps"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/capability"
          }
        },
        "manifest": {
          "$ref": "#/$defs/path"
        },
        "requested": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "granted",
              "triggers"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "granted": {
                "type": "boolean"
              },
              "triggers": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "granted": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/capability"
          }
        },
        "denied": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "unsafe": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "package",
              "capability",
              "kind",
              "rationale"
            ],
            "properties": {
              "package": {
                "$ref": "#/$defs/path"
              },
              "capability": {
                "type": "string",
                "minLength": 1
              },
              "kind": {
                "type": "string",
                "minLength": 1
              },
              "rationale": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        },
        "transitive_package_usage": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "root",
              "manifest",
              "name",
              "version",
              "workspace_only",
              "entrypoint",
              "dependencies",
              "members",
              "capability_scopes"
            ],
            "properties": {
              "root": {
                "$ref": "#/$defs/path"
              },
              "manifest": {
                "$ref": "#/$defs/path"
              },
              "name": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "version": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "workspace_only": {
                "type": "boolean"
              },
              "entrypoint": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "dependencies": {
                "type": "array"
              },
              "members": {
                "type": "array"
              },
              "capability_scopes": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/capability"
                }
              }
            }
          }
        },
        "stdlib_modules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "capability",
              "modules"
            ],
            "properties": {
              "capability": {
                "type": "string",
                "minLength": 1
              },
              "modules": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "module",
                    "triggers"
                  ],
                  "properties": {
                    "module": {
                      "$ref": "#/$defs/path"
                    },
                    "triggers": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "minLength": 1
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "cacheSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "source_hash",
        "imports"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/path"
        },
        "source_hash": {
          "type": "string",
          "minLength": 1
        },
        "imports": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "cacheKey": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "compiler",
        "debug",
        "generated_rust_hash",
        "lockfile_hash",
        "manifest_hash",
        "sources",
        "target",
        "version"
      ],
      "properties": {
        "compiler": {
          "type": "string",
          "minLength": 1
        },
        "debug": {
          "type": "boolean"
        },
        "generated_rust_hash": {
          "type": "string",
          "minLength": 1
        },
        "lockfile_hash": {
          "type": "string",
          "minLength": 1
        },
        "manifest_hash": {
          "type": "string",
          "minLength": 1
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cacheSource"
          }
        },
        "target": {
          "type": [
            "string",
            "null"
          ]
        },
        "version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "buildMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "debug",
        "lockfile",
        "lockfile_hash",
        "source_hash",
        "target"
      ],
      "properties": {
        "debug": {
          "type": "boolean"
        },
        "lockfile": {
          "$ref": "#/$defs/path"
        },
        "lockfile_hash": {
          "type": "string",
          "minLength": 1
        },
        "source_hash": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "macroExpansion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "macro_name",
        "call_site",
        "definition_site",
        "depth"
      ],
      "properties": {
        "macro_name": {
          "type": "string",
          "minLength": 1
        },
        "call_site": {
          "$ref": "#/$defs/macroSpan"
        },
        "definition_site": {
          "$ref": "#/$defs/macroSpan"
        },
        "depth": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "macroSpan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "line",
        "column"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/path"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
