{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axiomlang.dev/schemas/axiom-production-language-readiness-v1.schema.json",
  "title": "AxiOM Production Language Readiness v1",
  "type": "object",
  "required": ["schemaVersion", "schema", "umbrellaIssue", "rows"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "schema": { "const": "axiom.production_language.readiness.v1" },
    "umbrellaIssue": { "type": "integer", "minimum": 1 },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/row" }
    }
  },
  "$defs": {
    "tier": {
      "enum": ["syntax_only", "static_spike", "runtime_complete", "production_qualified"]
    },
    "row": {
      "type": "object",
      "required": [
        "id",
        "track",
        "requirement",
        "requiredForProduction",
        "targetTier",
        "currentTier",
        "status",
        "governingIssue",
        "dependencies",
        "evidence",
        "validatingCommand",
        "rustCaptureRisk",
        "agentInspectionImpact"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "track": { "type": "string", "minLength": 1 },
        "requirement": { "type": "string", "minLength": 1 },
        "requiredForProduction": { "type": "boolean" },
        "targetTier": { "$ref": "#/$defs/tier" },
        "currentTier": { "$ref": "#/$defs/tier" },
        "status": { "enum": ["implemented", "partial", "blocked"] },
        "governingIssue": { "type": "integer", "minimum": 1 },
        "blockerIssues": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 1 }
        },
        "dependencies": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 1 }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "validatingCommand": { "type": "string", "minLength": 1 },
        "rustCaptureRisk": { "enum": ["low", "medium", "high", "critical"] },
        "agentInspectionImpact": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      }
    }
  }
}
