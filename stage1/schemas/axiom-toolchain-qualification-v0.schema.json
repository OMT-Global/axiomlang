{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axiomlang.dev/schemas/axiom-toolchain-qualification-v0.schema.json",
  "title": "Axiom Toolchain Qualification Evidence v0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "trigger", "headSha", "target", "status", "durationMs", "failureClass", "artifactPaths", "checks"],
  "properties": {
    "schema": { "const": "axiom.toolchain_qualification.v0" },
    "trigger": { "type": "string", "minLength": 1 },
    "headSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "target": { "type": "string", "minLength": 1 },
    "status": { "enum": ["passed", "failed", "skipped"] },
    "durationMs": { "type": "integer", "minimum": 0 },
    "failureClass": { "enum": ["none", "product_failure", "infrastructure_failure", "infrastructure_skip"] },
    "artifactPaths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "command", "target", "required", "status", "durationMs", "failureClass", "exitCode", "artifacts"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "command": { "type": "string", "minLength": 1 },
          "target": { "type": "string", "minLength": 1 },
          "required": { "const": true },
          "status": { "enum": ["passed", "failed", "skipped"] },
          "durationMs": { "type": "integer", "minimum": 0 },
          "failureClass": { "enum": ["none", "product_failure", "infrastructure_failure", "infrastructure_skip"] },
          "exitCode": { "type": "integer" },
          "artifacts": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
        }
      }
    }
  }
}
