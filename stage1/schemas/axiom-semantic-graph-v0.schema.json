{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axiom-lang.dev/schemas/axiom-semantic-graph-v0.schema.json",
  "title": "Axiom Semantic Graph v0",
  "type": "object",
  "required": ["schema_version", "ok", "command", "project", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "axiom.stage1.v1"
    },
    "ok": {
      "const": true
    },
    "command": {
      "const": "inspect graph"
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }
  },
  "$defs": {
    "nodeId": {
      "type": "string",
      "pattern": "^axiom://[A-Za-z0-9._~:/#@!$&'()*+,;=%-]+$"
    },
    "node": {
      "type": "object",
      "required": ["id", "kind", "name", "span"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/nodeId"
        },
        "kind": {
          "enum": ["axiom", "capability", "evidence"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "span": {
          "$ref": "#/$defs/span"
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "assertion": {
          "type": "string",
          "minLength": 1
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/input"
          }
        },
        "effects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/effect"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "edge": {
      "type": "object",
      "required": ["from", "kind", "to"],
      "additionalProperties": false,
      "properties": {
        "from": {
          "$ref": "#/$defs/nodeId"
        },
        "kind": {
          "enum": ["preserves", "requires_evidence"]
        },
        "to": {
          "$ref": "#/$defs/nodeId"
        }
      }
    },
    "span": {
      "type": "object",
      "required": ["path", "line", "column"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "input": {
      "type": "object",
      "required": ["name", "ty"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "ty": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "effect": {
      "type": "object",
      "required": ["kind", "target"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": ["read", "write", "emit"]
        },
        "target": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
