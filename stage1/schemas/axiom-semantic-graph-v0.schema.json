{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axiom-lang.dev/schemas/axiom-semantic-graph-v0.schema.json",
  "title": "Axiom Semantic Graph v0",
  "type": "object",
  "required": [
    "schema_version",
    "schema",
    "ok",
    "command",
    "project",
    "lockfile_status",
    "lockfile_packages",
    "packages",
    "modules",
    "stdlib_modules",
    "cycles",
    "import_errors",
    "nodes",
    "edges"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "axiom.stage1.v1"
    },
    "schema": {
      "type": "string",
      "minLength": 1
    },
    "ok": {
      "type": "boolean"
    },
    "command": {
      "const": "inspect graph"
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "lockfile_status": {
      "enum": [
        "valid",
        "invalid"
      ]
    },
    "lockfile_packages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lockfilePackage"
      }
    },
    "packages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/package"
      }
    },
    "modules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/module"
      }
    },
    "stdlib_modules": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "cycles": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "import_errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/importError"
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }
  },
  "$defs": {
    "lockfilePackage": {
      "type": "object",
      "required": [
        "name",
        "version",
        "source"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "package": {
      "type": "object",
      "required": [
        "name",
        "root",
        "manifest",
        "dependencies",
        "workspace_members"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "root": {
          "type": "string",
          "minLength": 1
        },
        "manifest": {
          "type": "string",
          "minLength": 1
        },
        "dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packageDependency"
          }
        },
        "workspace_members": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "packageDependency": {
      "type": "object",
      "required": [
        "name",
        "path"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "module": {
      "type": "object",
      "required": [
        "path",
        "imports"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "imports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/moduleImport"
          }
        },
        "functions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/function"
          }
        },
        "type_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "moduleImport": {
      "type": "object",
      "required": [
        "path",
        "resolved",
        "is_stdlib"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "resolved": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "is_stdlib": {
          "type": "boolean"
        }
      }
    },
    "importError": {
      "type": "object",
      "required": [
        "module",
        "import",
        "message"
      ],
      "additionalProperties": false,
      "properties": {
        "module": {
          "type": "string",
          "minLength": 1
        },
        "import": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "function": {
      "type": "object",
      "required": [
        "name",
        "signature",
        "span",
        "capabilities"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "signature": {
          "type": "string",
          "minLength": 1
        },
        "span": {
          "$ref": "#/$defs/span"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "nodeId": {
      "type": "string",
      "pattern": "^axiom://[A-Za-z0-9._~:/#@!$&'()*+,;=%-]+$"
    },
    "node": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "name",
        "span"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/nodeId"
        },
        "kind": {
          "enum": [
            "axiom",
            "capability",
            "evidence",
            "decision"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "span": {
          "$ref": "#/$defs/span"
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "proposed",
            "accepted",
            "superseded",
            "rejected"
          ]
        },
        "description": {
          "type": "string"
        },
        "assertion": {
          "type": "string",
          "minLength": 1
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/input"
          }
        },
        "effects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/effect"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "edge": {
      "type": "object",
      "required": [
        "from",
        "kind",
        "to"
      ],
      "additionalProperties": false,
      "properties": {
        "from": {
          "$ref": "#/$defs/nodeId"
        },
        "kind": {
          "enum": [
            "preserves",
            "requires_evidence",
            "verified_by",
            "violates",
            "depends_on"
          ]
        },
        "to": {
          "$ref": "#/$defs/nodeId"
        }
      }
    },
    "span": {
      "type": "object",
      "required": [
        "path",
        "line",
        "column"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "input": {
      "type": "object",
      "required": [
        "name",
        "ty"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "ty": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "effect": {
      "type": "object",
      "required": [
        "kind",
        "target"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "read",
            "write",
            "emit"
          ]
        },
        "target": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
