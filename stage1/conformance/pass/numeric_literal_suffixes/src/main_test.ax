let signed8: i8 = 1i8
let signed16: i16 = 1i16
let signed32: i32 = 1i32
let signed64: i64 = 1i64
let unsigned8: u8 = 2u8
let unsigned16: u16 = 2u16
let unsigned32: u32 = 2u32
let unsigned64: u64 = 2u64
let float32: f32 = 3.14f32
let float64: f64 = 3.14f64

print signed32
print signed8
print signed16
print signed64
print unsigned64
print unsigned8
print unsigned16
print unsigned32
print float32 > 3.0f32
print float64 > 3.0f64
