macro vec_values {
($($value:expr),*) => ([$($value),*]);
}

macro introduce_local {
() => {
let x: int = 0
print x
};
}

macro add_one {
($value:expr) => ($value + 1);
}

macro add_two {
($value:expr) => (add_one!(add_one!($value)));
}

let x: int = 9
introduce_local!()
print x
let values: [int] = vec_values!(1, 2, 3)
print values[1]
print add_two!(40)
