// top-level comment before a struct
struct Point { // trailing comment after declaration opener
// comment inside a struct body
x: int // trailing field comment
y: int // second trailing field comment
}

// comment before a function
fn describe(point: Point): string { // trailing comment after function signature
// comment inside a function body
let url: string = "https://example.test//path" // comment after a string containing //
if point.x > 0 { // trailing comment after block opener
// comment inside a nested block
return url // trailing return comment
}
return "origin: " + url // trailing expression comment
}

fn label(value: Option<int>): string {
match value { // trailing match comment
// comment inside a match block
Some(number) { // trailing arm comment
// comment inside a match arm
return "some " + json_stringify_int(number) // trailing intrinsic call comment
}
None {
return "none"
}
}
}

let origin: Point = Point { x: 0, y: 0 } // trailing aggregate literal comment
// comment between statements
print describe(origin) // trailing print comment
print label(Some(7)) // trailing option constructor comment
print label(None) // trailing none constructor comment
