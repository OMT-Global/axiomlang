import "models.ax"

fn maybe_job(ready: bool): Option<Job> {
if ready {
return Some(Job { id: 7, label: "queued" })
}
return None
}

fn load_job(ready: bool): Result<Job, string> {
if ready {
return Ok(Job { id: 9, label: "built" })
}
return Err("boom")
}

fn describe(job: Option<Job>): string {
match job {
Some(info) {
return info.label
}
None {
return "none"
}
}
}

fn render(result: Result<Job, string>): string {
match result {
Ok(info) {
return info.label
}
Err(message) {
return message
}
}
}

print describe(maybe_job(true))
print describe(maybe_job(false))
print render(load_job(true))
print render(load_job(false))

fn describe_iflet(job: Option<Job>): string {
if let Some(info) = job {
return info.label
}
return "none"
}

fn render_iflet(result: Result<Job, string>): string {
if let Ok(info) = result {
return info.label
} else {
return "error"
}
}

print describe_iflet(maybe_job(true))
print describe_iflet(maybe_job(false))
print render_iflet(load_job(true))
print render_iflet(load_job(false))

enum IfLetFallbackConflict {
Picked(int)
Ignored { render_conflicting_iflet_fallback: int, label: string }
Other(int)
}

fn render_conflicting_iflet_fallback(item: IfLetFallbackConflict): string {
let __if_let_ignored_0: int = 42
if let Picked(_value) = item {
return "picked"
} else {
return "fallback"
}
}

print render_conflicting_iflet_fallback(Picked(1))
print render_conflicting_iflet_fallback(Ignored { render_conflicting_iflet_fallback: 2, label: "ignored" })
print render_conflicting_iflet_fallback(Other(3))
