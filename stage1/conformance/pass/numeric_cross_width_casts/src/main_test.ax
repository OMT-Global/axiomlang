let wide_signed: i64 = 7i64
let narrow_signed: i32 = wide_signed as i32

let byte: u8 = 255u8
let widened_unsigned: i32 = byte as i32

let signed32: i32 = 3i32
let float32: f32 = signed32 as f32

let float64: f64 = -4.75f64
let signed64: i64 = float64 as i64

let same: i32 = 42i32 as i32

print narrow_signed
print widened_unsigned
print float32 as int
print signed64
print same
