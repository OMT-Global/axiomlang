import "std/collections.ax"
import "std/testing.ax"

let numbers: [int] = [4, 5, 6, 7]
let middle: &[int] = window<int>(numbers[:], 1, 3)
let prefix: &[int] = take<int>(numbers[:], 2)
let suffix: &[int] = skip<int>(numbers[:], 2)

let count_ok: int = property("collections count", count<int>(numbers[:]) == 4)
let empty_ok: int = property("collections empty slice", is_empty<int>(take<int>(numbers[:], 0)))
let middle_ok: int = property("collections window", first(middle) == 5 && last(middle) == 6)
let bounds_ok: int = property("collections take skip", last(prefix) == 5 && first(suffix) == 6)

print count_ok + empty_ok + middle_ok + bounds_ok
