import "std/net.ax"

match resolve("localhost") {
Some(_address) {
print true
}
None {
print false
}
}

match tcp_listen_loopback_once("tcp pong", 1000) {
Some(port) {
print port > 0
}
None {
print "tcp listen none"
}
}

match udp_bind_loopback_once("udp pong", 1000) {
Some(port) {
print port > 0
}
None {
print "udp bind none"
}
}
