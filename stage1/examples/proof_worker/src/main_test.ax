import "std/async.ax"
import "std/env.ax"
import "std/fs.ax"
import "std/json.ax"
import "std/time.ax"
import "jobs.ax"
import "state.ax"

async fn process(queue: string, worker: string, job: string, result: string, processed: int): string {
return "{" + field_string("workload", "proof-worker") + "," + field_string("worker", worker) + "," + field_string("queue", queue) + "," + field_string("job", job) + "," + field_string("result", result) + "," + field_int("processed", processed) + "}"
}

let output_dir: int = mkdir_all("scratch/proof_worker")

let queue_one: AsyncChannel<string> = channel<string>()
let queued_one: AsyncChannel<string> = await send<string>(queue_one, "ingest")
let job_one: Option<string> = await recv<string>(queued_one)
match job_one {
Some(payload_one) {
let handle_one: JoinHandle<string> = spawn<string>(process("default", worker_name(get_env("AXIOM_STAGE1_WORKER")), payload_one, handle("ingest"), 1))
let output_one: string = await join<string>(handle_one)
let write_one: int = write_file("scratch/proof_worker/results.txt", output_one)
}
None {
print "idle"
}
}
let queue_two: AsyncChannel<string> = channel<string>()
