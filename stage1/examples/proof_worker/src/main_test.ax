let job_two: Option<string> = await recv<string>(queued_two)
match job_two {
Some(payload_two) {
let handle_two: JoinHandle<string> = spawn<string>(process("default", worker_name(get_env("AXIOM_STAGE1_WORKER")), payload_two, handle("validate"), 2))
let output_two: string = await join<string>(handle_two)
let write_two: int = append_file("scratch/proof_worker/results.txt", "\n" + output_two)
}
None {
