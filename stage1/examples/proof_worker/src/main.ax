import "std/async.ax"
import "std/env.ax"
import "std/time.ax"
import "jobs.ax"
import "state.ax"

async fn run_once(queue: AsyncChannel<string>): string {
let next: Option<string> = await recv<string>(queue)
match next {
Some(job) {
return handle(job)
}
None {
return "idle"
}
}
}

let name: string = worker_name(get_env("AXIOM_STAGE1_WORKER"))
