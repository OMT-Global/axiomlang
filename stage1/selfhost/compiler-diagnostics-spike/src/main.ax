print "stable_code type unknown = " + code_text(stable_diagnostic_code("type", "unknown type name Widget"))
print "stable_code type expected = " + code_text(stable_diagnostic_code("type", "expected int, got bool"))
print "stable_code type mismatch = " + code_text(stable_diagnostic_code("type", "arm type mismatch in match expression"))
print "stable_code type fallback = " + code_text(stable_diagnostic_code("type", "trait bound failure"))
print "stable_code ownership = " + code_text(stable_diagnostic_code("ownership", "use of moved value greeting"))
print "stable_code codegen = " + code_text(stable_diagnostic_code("codegen", "internal lowering failure"))
print "stable_code build = " + code_text(stable_diagnostic_code("build", "native backend failed to produce artifact"))
print "stable_code runtime = " + code_text(stable_diagnostic_code("runtime", "index out of bounds"))
print "stable_code control missing-return = " + code_text(stable_diagnostic_code("control", "function does not return along all paths"))
print "stable_code control unreachable = " + code_text(stable_diagnostic_code("control", "unreachable statement after panic"))
print "stable_code control fallback = " + code_text(stable_diagnostic_code("control", "loop guard shape rejected"))
print "stable_code fmt = " + code_text(stable_diagnostic_code("fmt", "formatting failed for source"))
print "stable_code source = " + code_text(stable_diagnostic_code("source", "path is not an .ax source file"))
print "stable_code json = " + code_text(stable_diagnostic_code("json", "serialization failed for envelope"))
