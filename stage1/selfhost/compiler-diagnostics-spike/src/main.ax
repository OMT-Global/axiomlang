print "render path-line = " + render_diagnostic(Some("src/main.ax"), Some(3), None, "use of moved value greeting")
print "render path-only = " + render_diagnostic(Some("src/main.ax"), None, None, "use of moved value greeting")
print "render message-only = " + render_diagnostic(None, None, None, "use of moved value greeting")
print "plausible empty-needle = " + bool_text(is_plausible_suggestion(0, 3, 1))
print "plausible empty-candidate = " + bool_text(is_plausible_suggestion(3, 0, 1))
print "plausible short-close = " + bool_text(is_plausible_suggestion(5, 5, 2))
