print "repair ownership = " + hint_text(repair_hint("ownership"))
print "repair manifest = " + hint_text(repair_hint("manifest"))
print "repair capability = " + hint_text(repair_hint("capability"))
print "repair import = " + hint_text(repair_hint("import"))
