import "std/regex.ax"

// Self-hosting feasibility spike for the compiler.diagnostics package (#1253).
// This slice mirrors stage1/crates/axiomc/src/diagnostics.rs: stable diagnostic
// code classification, repair hints, source-location rendering, and the
// suggestion plausibility predicate. Substring checks use std/regex is_match
// because the AxiOM surface has no string-contains primitive yet; the needles
// below are literal words and spaces, so they are regex-safe.

struct RepairHint {
action: string
edit: Option<string>
command: Option<string>
}

fn contains(text: string, needle: string): bool {
return is_match(needle, text)
}

pub fn stable_diagnostic_code(kind: string, message: string): Option<string> {
if kind == "parse" {
if contains(string_clone(message), "missing closing brace") {
return Some("parse.missing_closing_brace")
}
if contains(string_clone(message), "unexpected closing brace") {
return Some("parse.unexpected_closing_brace")
}
if contains(string_clone(message), "not supported") {
return Some("parse.unsupported_syntax")
}
if contains(string_clone(message), "unexpected") {
return Some("parse.unexpected_token")
}
if contains(string_clone(message), "missing") {
return Some("parse.missing_token")
}
return Some("parse.invalid_syntax")
}
if kind == "manifest" {
if contains(string_clone(message), "dependency path") {
return Some("manifest.bad_dependency_path")
}
if contains(string_clone(message), "resolves outside") {
return Some("manifest.bad_dependency_path")
}
if contains(string_clone(message), "capability") {
return Some("manifest.invalid_capability")
}
return Some("manifest.invalid")
}
if kind == "import" {
if contains(string_clone(message), "circular") {
return Some("import.cycle")
}
if contains(string_clone(message), "cycle") {
return Some("import.cycle")
}
if contains(string_clone(message), "not found") {
return Some("import.unresolved")
}
if contains(string_clone(message), "failed to read") {
return Some("import.unresolved")
}
if contains(string_clone(message), "missing import") {
return Some("import.unresolved")
}
return Some("import.invalid")
}
if kind == "capability" {
if contains(string_clone(message), "requires") {
return Some("capability.denied")
}
if contains(string_clone(message), "not enabled") {
return Some("capability.denied")
}
return Some("capability.invalid")
}
if kind == "type" {
if contains(string_clone(message), "undefined") {
return Some("type.undefined_symbol")
}
if contains(string_clone(message), "unknown") {
return Some("type.undefined_symbol")
}
if contains(string_clone(message), "expected") {
return Some("type.mismatch")
}
if contains(string_clone(message), "mismatch") {
return Some("type.mismatch")
}
return Some("type.invalid")
}
if kind == "ownership" {
return Some("ownership.invalid")
}
if kind == "codegen" {
return Some("codegen.internal")
}
if kind == "build" {
return Some("build.failed")
}
if kind == "runtime" {
return Some("runtime.failed")
}
if kind == "control" {
if contains(string_clone(message), "does not return along all paths") {
return Some("control.missing_return")
}
if contains(string_clone(message), "unreachable") {
return Some("control.unreachable_statement")
}
return Some("control.invalid")
}
if kind == "fmt" {
return Some("fmt.failed")
}
if kind == "source" {
return Some("source.invalid")
}
if kind == "json" {
return Some("json.serialization_failed")
}
return None
}

pub fn repair_hint(kind: string): Option<RepairHint> {
if kind == "parse" {
return Some(edit_source_hint())
}
if kind == "type" {
return Some(edit_source_hint())
}
if kind == "ownership" {
return Some(edit_source_hint())
}
if kind == "manifest" {
return Some(edit_manifest_hint())
}
if kind == "capability" {
return Some(edit_manifest_hint())
}
if kind == "import" {
return Some(RepairHint { action: "edit_import", edit: Some("Fix the quoted relative import path or add the missing imported source file."), command: None })
}
if kind == "fmt" {
return Some(RepairHint { action: "run_command", edit: None, command: Some("axiomc fmt <path>") })
}
if kind == "source" {
return Some(RepairHint { action: "check_path", edit: Some("Use an existing .ax source path or package directory."), command: None })
}
if kind == "build" {
return Some(rerun_command_hint())
}
if kind == "codegen" {
return Some(rerun_command_hint())
}
if kind == "runtime" {
return Some(rerun_command_hint())
}
return None
}

fn edit_source_hint(): RepairHint {
return RepairHint { action: "edit_source", edit: Some("Update the source at the reported span and rerun `axiomc check --json`."), command: None }
}

fn edit_manifest_hint(): RepairHint {
return RepairHint { action: "edit_manifest", edit: Some("Update axiom.toml with the narrowest required package, dependency, or capability change."), command: None }
}

fn rerun_command_hint(): RepairHint {
return RepairHint { action: "rerun_command", edit: Some("Review the compiler message and rerun the failed command after source changes."), command: None }
}

pub fn render_diagnostic(path: Option<string>, line: Option<int>, column: Option<int>, message: string): string {
match path {
Some(path_text) {
match line {
Some(line_number) {
match column {
Some(column_number) {
return path_text + ":" + json_stringify_int(line_number) + ":" + json_stringify_int(column_number) + ": " + message
}
None {
return path_text + ": " + message
}
}
}
None {
return path_text + ": " + message
}
}
}
None {
return message
}
}
}

pub fn is_plausible_suggestion(needle_length: int, candidate_length: int, distance: int): bool {
if needle_length == 0 {
return false
}
if candidate_length == 0 {
return false
}
if distance <= 2 {
return true
}
let max_length: int = needle_length
if candidate_length > max_length {
max_length = candidate_length
}
if max_length >= 6 {
if distance <= 3 {
return true
}
}
return false
}

fn code_text(value: Option<string>): string {
match value {
Some(code) {
return "some:" + code
}
None {
return "none"
}
}
}

fn text_or_none(value: Option<string>): string {
match value {
Some(text) {
return text
}
None {
return "none"
}
}
}

fn hint_text(value: Option<RepairHint>): string {
match value {
Some(hint) {
return "action=" + hint.action + " edit=" + text_or_none(hint.edit) + " command=" + text_or_none(hint.command)
}
None {
return "none"
}
}
}

fn bool_text(value: bool): string {
if value {
return "true"
}
return "false"
}

print "stable_code parse missing-closing = " + code_text(stable_diagnostic_code("parse", "missing closing brace after block"))
print "stable_code parse unexpected-closing = " + code_text(stable_diagnostic_code("parse", "unexpected closing brace at top level"))
print "stable_code parse unsupported = " + code_text(stable_diagnostic_code("parse", "match guards are not supported in stage1"))
