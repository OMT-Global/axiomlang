print "stable_code parse missing-token = " + code_text(stable_diagnostic_code("parse", "missing argument after comma"))
print "stable_code parse fallback = " + code_text(stable_diagnostic_code("parse", "invalid identifier"))
print "stable_code manifest dependency-path = " + code_text(stable_diagnostic_code("manifest", "dependency path escapes the package root"))
